{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/app/*": ["app/*"],
      "@/shared/*": ["shared/*"],
      "@/entities/*": ["entities/*"],
      "@/features/*": ["features/*"],
      "@/pages/*": ["pages/*"],
      "@/processes/*": ["processes/*"],
      "@/widgets/*": ["widgets/*"],
      "*": ["./src/*"],
    },
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "ESNext",
    "target": "ES5",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS",
    },
  },
  "include": ["src", "config", "jest.config.ts", "webpack.config.ts"],
}
